GEMINI_API_KEY=your_key_here
ADMIN_PASSWORD=viraliq-admin

# Secret used to sign auth JWTs. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_to_a_long_random_string

# Comma-separated list of allowed frontend origins for CORS.
# Local dev default is http://localhost:3000. In production set this to your
# deployed frontend URL, e.g. https://viraliq.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Database connection.
# Local dev: leave unset (defaults to sqlite+aiosqlite:///./viraliq.db)
# Production (Neon): paste your DIRECT connection string here (not the pooler URL).
#   Get it from: Neon console → your project → Connection Details → Direct
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── Transactional email (password reset, email verification, welcome) ──
# Railway blocks ALL outbound SMTP ports, so PRODUCTION must use Brevo's HTTP API.
# Get the key from Brevo → SMTP & API → API Keys (starts with "xkeysib-").
# Without it (and without SMTP below) signup still works, but no code is emailed.
# BREVO_API_KEY=xkeysib-...
# The "From" address must be a Brevo-verified sender.
EMAIL_FROM=Surge <you@example.com>
# Where email links point (welcome email button, etc.).
FRONTEND_URL=https://surge-chi-khaki.vercel.app
# SMTP is the LOCAL-DEV fallback only (used when BREVO_API_KEY is unset).
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=...@smtp-brevo.com
# SMTP_PASS=...

# ── Google sign-in (optional) ──
# OAuth client ID from Google Cloud Console (…apps.googleusercontent.com).
# When unset, /api/auth/google returns 503 and the frontend hides the button —
# email/password signup is unaffected. The SAME value goes to the frontend as
# NEXT_PUBLIC_GOOGLE_CLIENT_ID.
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
