# URL of the CraftLint backend API.
# Local dev: http://localhost:8000
# Production: your deployed backend URL, e.g. https://surge-production-8973.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth client ID (…apps.googleusercontent.com) — SAME value as the
# backend's GOOGLE_CLIENT_ID. When unset, the "Sign in with Google" button is
# hidden and email/password auth works unchanged.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=...apps.googleusercontent.com

# Canonical site URL used for metadataBase, og:url, and the OG image's
# displayed URL text. Set to the production domain (e.g. https://craftlint.com)
# once DNS is live for it; until then, leave unset to fall back to the
# current Vercel URL (https://surge-chi-khaki.vercel.app).
# NEXT_PUBLIC_SITE_URL=https://craftlint.com
